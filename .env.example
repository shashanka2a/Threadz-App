NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=your_publishable_key
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key
ADMIN_USERNAME=admin
ADMIN_PASSWORD=your_admin_password
NEXT_PUBLIC_RAZORPAY_KEY_ID=rzp_test_your_key_id
# Must pair with the Key ID above (Dashboard → Settings → API Keys → Key Secret)
RAZORPAY_KEY_SECRET=your_razorpay_key_secret
NEXT_PUBLIC_SITE_URL=https://threadz.studio
# Postgres URI for npm run db:setup (Dashboard → Settings → Database)
SUPABASE_DB_URL=postgresql://postgres.[ref]:[PASSWORD]@aws-0-[region].pooler.supabase.com:6543/postgres

# Cloudinary (Dashboard → API Keys)
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret
# Unsigned upload preset (Dashboard → Upload → Upload presets)
CLOUDINARY_UPLOAD_PRESET=ml_default
